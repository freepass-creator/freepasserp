rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 상품 이미지: 로그인 사용자 읽기 (카탈로그 공개용)
    match /product-images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 계약 서류 (신분증, 면허증 등): 업로드한 본인만 읽기/쓰기
    match /contract-files/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 공지 이미지: 로그인 사용자 읽기
    match /notice-images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 사용자 서류 (사업자등록증 등): 업로드한 본인만 읽기/쓰기
    match /user-docs/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 기본 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
